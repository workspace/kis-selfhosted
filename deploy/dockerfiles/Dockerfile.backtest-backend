FROM python:3.13-slim

WORKDIR /app

RUN pip install uv

COPY backtester/pyproject.toml backtester/uv.lock* ./
RUN if [ -f uv.lock ]; then uv sync --frozen; else uv sync; fi

COPY backtester/ .

ENV KIS_CONFIG_DIR=/app/kis-config

EXPOSE 8002
CMD ["uv", "run", "uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8002"]
