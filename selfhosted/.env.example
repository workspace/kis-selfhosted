# ─── Auth (Client Credentials) ───────────────────────────────
# 아래 명령어로 각각 생성하세요:
#   CLIENT_ID:     python3 -c "import secrets; print(secrets.token_urlsafe(16))"
#   CLIENT_SECRET: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   JWT_SECRET:    python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#
# 또는 openssl 사용:
#   openssl rand -base64 24  (CLIENT_ID)
#   openssl rand -base64 48  (CLIENT_SECRET / JWT_SECRET)
CLIENT_ID=
CLIENT_SECRET=
JWT_SECRET=

# External port (NPM forwards to this)
GATEWAY_PORT=8080

# Lean Docker volume name (auto-set in docker-compose)
# Override if using a custom COMPOSE_PROJECT_NAME
# LEAN_DOCKER_VOLUME_NAME=selfhosted_lean-workspace

# GitHub URL for landing page
GITHUB_URL=https://github.com/koreainvestment/open-trading-api

# ─── KIS API ─────────────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=
KIS_HTS_ID=
KIS_ACCT_STOCK=
KIS_ACCT_FUTURE=
KIS_PAPER_STOCK=
KIS_PAPER_FUTURE=
KIS_PROD_TYPE=01
# User-Agent (Chrome F12 > Console > navigator.userAgent)
KIS_USER_AGENT=Mozilla/5.0
